{
  "name": "@amcharts/amcharts5-mcp",
  "version": "1.1.1",
  "description": "MCP server for amCharts 5 — gives AI assistants on-demand access to amCharts docs, examples, and API reference",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "amcharts5-mcp": "src/index.js"
  },
  "files": [
    "src/",
    "content/",
    "extended/",
    "README.md"
  ],
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "prepublishOnly": "node -e \"const fs=require('fs');if(!fs.existsSync('content'))fs.mkdirSync('content');fs.cpSync('amcharts5-skill/amcharts5-skill/SKILL.md','content/SKILL.md');for(const f of fs.readdirSync('amcharts5-skill/amcharts5-skill/references').filter(x=>x.endsWith('.md')))fs.cpSync('amcharts5-skill/amcharts5-skill/references/'+f,'content/'+f)\"",
    "postpublish": "node -e \"require('fs').rmSync('content',{recursive:true,force:true})\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amcharts/amcharts5-mcp.git"
  },
  "homepage": "https://github.com/amcharts/amcharts5-mcp#readme",
  "bugs": {
    "url": "https://github.com/amcharts/amcharts5-mcp/issues"
  },
  "keywords": [
    "amcharts",
    "mcp",
    "model-context-protocol",
    "ai",
    "charts",
    "data-visualization",
    "claude",
    "cursor",
    "windsurf",
    "copilot",
    "vscode"
  ],
  "author": "amCharts",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "jsdom": "^29.0.0",
    "turndown": "^7.2.2"
  }
}
