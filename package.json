{
  "name": "@amcharts/amcharts5-mcp",
  "version": "1.1.0",
  "description": "MCP server for amCharts 5 — gives AI assistants on-demand access to amCharts docs, examples, and API reference",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "amcharts5-mcp": "src/index.js"
  },
  "files": [
    "src/",
    "content/",
    "extended/",
    "README.md"
  ],
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "prepublishOnly": "mkdir -p content && cp amcharts5-skill/amcharts5-skill/SKILL.md content/ && cp amcharts5-skill/amcharts5-skill/references/*.md content/",
    "postpublish": "rm -rf content"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amcharts/amcharts5-mcp.git"
  },
  "homepage": "https://github.com/amcharts/amcharts5-mcp#readme",
  "bugs": {
    "url": "https://github.com/amcharts/amcharts5-mcp/issues"
  },
  "keywords": [
    "amcharts",
    "mcp",
    "model-context-protocol",
    "ai",
    "charts",
    "data-visualization"
  ],
  "author": "amCharts",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "jsdom": "^29.0.0",
    "turndown": "^7.2.2"
  }
}
